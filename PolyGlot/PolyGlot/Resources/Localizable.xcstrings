        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解析响应，请重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法解析回應，請重試。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レスポンスを解析できません。再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "응답을 분석할 수 없습니다. 다시 시도해 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'analyser la réponse, veuillez réessayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo analizar la respuesta, intente de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Antwort konnte nicht verarbeitet werden, bitte erneut versuchen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रतिक्रिया पार्स नहीं हो सकी, कृपया पुनः प्रयास करें।"
